{
  "name": "hydra-code",
  "displayName": "Hydra Code",
  "description": "Monitor and orchestrate parallel AI coding agents — see every worker's status, git diff, and terminal output from one sidebar",
  "version": "0.1.26",
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "zhoujinjing",
  "license": "MIT",
  "icon": "resources/icon.png",
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "tmux",
    "worktree",
    "git",
    "git-worktree",
    "terminal",
    "session",
    "branch",
    "workflow",
    "ai-coding",
    "vibe-coding",
    "claude-code",
    "codex",
    "gemini",
    "sudocode",
    "sudo-code",
    "ai-agents",
    "parallel-development",
    "multi-branch",
    "coding-agent",
    "remote-ssh"
  ],
  "galleryBanner": {
    "color": "#1BB352",
    "theme": "dark"
  },
  "badges": [],
  "homepage": "https://github.com/joezhoujinjing/hydra",
  "bugs": {
    "url": "https://github.com/joezhoujinjing/hydra/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joezhoujinjing/hydra.git"
  },
  "main": "./out/extension.js",
  "bin": {
    "hydra": "./out/cli/index.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tmux-explorer",
          "title": "Hydra",
          "icon": "resources/hydra-activitybar.svg"
        }
      ]
    },
    "views": {
      "tmux-explorer": [
        {
          "id": "hydraCopilots",
          "name": "Copilots"
        },
        {
          "id": "hydraWorkers",
          "name": "Workers"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hydraCopilots",
        "contents": "Start a copilot to orchestrate AI workers."
      },
      {
        "view": "hydraCopilots",
        "contents": "[Start Copilot (Claude)](command:hydra.startCopilotClaude)",
        "when": "hydra.claudeAvailable"
      },
      {
        "view": "hydraCopilots",
        "contents": "[Start Copilot (Codex)](command:hydra.startCopilotCodex)",
        "when": "hydra.codexAvailable"
      },
      {
        "view": "hydraCopilots",
        "contents": "[Start Copilot (Gemini)](command:hydra.startCopilotGemini)",
        "when": "hydra.geminiAvailable"
      },
      {
        "view": "hydraCopilots",
        "contents": "No supported agents found on PATH.\nInstall [Claude Code](https://docs.anthropic.com/en/docs/claude-code), [Codex](https://github.com/openai/codex), or [Gemini CLI](https://github.com/google-gemini/gemini-cli).",
        "when": "hydra.noAgentsAvailable"
      }
    ],
    "commands": [
      {
        "command": "tmux.attachCreate",
        "title": "Hydra: Attach/Create Session"
      },
      {
        "command": "tmux.newTask",
        "title": "Hydra: Create Worker"
      },
      {
        "command": "tmux.removeTask",
        "title": "Hydra: Remove"
      },
      {
        "command": "tmux.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tmux.attach",
        "title": "Open in Terminal"
      },
      {
        "command": "tmux.attachInEditor",
        "title": "Attach in Editor"
      },
      {
        "command": "tmux.openWorktree",
        "title": "Open in New Window"
      },
      {
        "command": "tmux.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "tmux.newPane",
        "title": "New Pane (Split)"
      },
      {
        "command": "tmux.newWindow",
        "title": "New Window"
      },
      {
        "command": "tmux.terminalPaste",
        "title": "Hydra: Smart Paste (Image Support)"
      },
      {
        "command": "tmux.pasteImage",
        "title": "Hydra: Paste Image from Clipboard"
      },
      {
        "command": "tmux.createWorktreeFromBranch",
        "title": "Create Worktree from This Branch"
      },
      {
        "command": "hydra.createCopilot",
        "title": "Hydra: Create Copilot",
        "icon": "$(hubot)"
      },
      {
        "command": "hydra.createWorker",
        "title": "Hydra: Create Worker",
        "icon": "$(server-process)"
      },
      {
        "command": "hydra.startCopilotClaude",
        "title": "Hydra: Start Copilot (Claude)"
      },
      {
        "command": "hydra.startCopilotCodex",
        "title": "Hydra: Start Copilot (Codex)"
      },
      {
        "command": "hydra.startCopilotGemini",
        "title": "Hydra: Start Copilot (Gemini)"
      }
    ],
    "keybindings": [
      {
        "command": "tmux.terminalPaste",
        "key": "cmd+v",
        "when": "terminalFocus",
        "mac": "cmd+v",
        "linux": "ctrl+shift+v"
      }
    ],
    "configuration": {
      "title": "Hydra",
      "properties": {
        "tmuxWorktree.multiplexer": {
          "type": "string",
          "enum": [
            "tmux"
          ],
          "default": "tmux",
          "markdownDescription": "Terminal multiplexer backend (`tmux`)."
        },
        "tmuxWorktree.baseBranch": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the base branch used when creating new task worktrees (e.g. `master`, `origin/master`). Leave empty to auto-detect from `origin/main`, `main`, `origin/master`, `master`."
        },
        "hydra.baseBranch": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the base branch used when creating new worker worktrees (e.g. `master`, `origin/master`). Leave empty to auto-detect. Takes precedence over `tmuxWorktree.baseBranch`."
        },
        "hydra.defaultAgent": {
          "type": "string",
          "enum": [
            "claude",
            "codex",
            "gemini",
            "custom"
          ],
          "default": "claude",
          "markdownDescription": "Default AI agent to launch in new copilot/worker sessions."
        },
        "hydra.agentCommands": {
          "type": "object",
          "default": {
            "claude": "claude",
            "codex": "codex",
            "gemini": "gemini"
          },
          "markdownDescription": "Map of agent type to shell command used to launch the agent."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "tmux.refresh",
          "when": "view == hydraCopilots || view == hydraWorkers",
          "group": "navigation"
        },
        {
          "command": "hydra.createCopilot",
          "when": "view == hydraCopilots",
          "group": "navigation"
        },
        {
          "command": "hydra.createWorker",
          "when": "view == hydraWorkers",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tmux.attach",
          "when": "(view == hydraCopilots || view == hydraWorkers) && (viewItem == 'workerItem' || viewItem == 'inactiveWorkerItem' || viewItem == 'copilotItem')",
          "group": "1_open"
        },
        {
          "command": "tmux.openWorktree",
          "when": "(view == hydraCopilots || view == hydraWorkers) && (viewItem == 'workerItem' || viewItem == 'inactiveWorkerItem')",
          "group": "1_open"
        },
        {
          "command": "tmux.copyPath",
          "when": "(view == hydraCopilots || view == hydraWorkers) && (viewItem == 'workerItem' || viewItem == 'inactiveWorkerItem')",
          "group": "2_copy"
        },
        {
          "command": "tmux.removeTask",
          "when": "(view == hydraCopilots || view == hydraWorkers) && (viewItem == 'workerItem' || viewItem == 'inactiveWorkerItem' || viewItem == 'copilotItem')",
          "group": "9_danger"
        }
      ]
    }
  },
  "activationEvents": [
    "onView:hydraCopilots"
  ],
  "scripts": {
    "compile": "tsc -p ./ && node scripts/postcompile.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
